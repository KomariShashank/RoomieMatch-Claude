{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    {
      "src": "../api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/health", "dest": "../api/index.py" },
    { "src": "/auth/(.*)", "dest": "../api/index.py" },
    { "src": "/profile/(.*)", "dest": "../api/index.py" },
    { "src": "/matches", "dest": "../api/index.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}