{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/health", "dest": "api/index.py" },
    { "src": "/auth/(.*)", "dest": "api/index.py" },
    { "src": "/profile/(.*)", "dest": "api/index.py" },
    { "src": "/matches", "dest": "api/index.py" },
    { "src": "/static/(.*)", "dest": "/frontend/build/static/$1" },
    { "src": "/manifest.json", "dest": "/frontend/build/manifest.json" },
    { "src": "/favicon.ico", "dest": "/frontend/build/favicon.ico" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/frontend/build/index.html" }
  ]
}