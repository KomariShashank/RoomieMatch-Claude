{
  "version": 2,
  "framework": null,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/health", "dest": "api/index.py" },
    { "src": "/auth/(.*)", "dest": "api/index.py" },
    { "src": "/profile/(.*)", "dest": "api/index.py" },
    { "src": "/matches", "dest": "api/index.py" },
    { "src": "/static/(.*)", "dest": "/frontend/static/$1" },
    { "src": "/(favicon.ico|manifest.json|asset-manifest.json|robots.txt|logo.*\\.png)", "dest": "/frontend/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/frontend/index.html" }
  ]
}